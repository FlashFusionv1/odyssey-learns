        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SecurityAlertRequest"
              },
              "example": {
                "severity": "high",
                "type": "suspicious_activity",
                "message": "Multiple failed login attempts detected",
                "metadata": {
                  "ip": "192.168.1.1",
                  "attempts": 5
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alert sent",
