              }
            }
          }
        }
      }
    },
    "/verify-backups": {
      "post": {
        "tags": ["System"],
        "summary": "Verify Backups",
        "description": "Verify database backup integrity and record counts",
        "operationId": "verifyBackups",
        "security": [],
        "responses": {
          "200": {
            "description": "Backup verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyBackupsResponse"
                },
                "example": {
                  "timestamp": "2026-01-23T12:00:00.000Z",
                  "status": "success",
                  "database_accessible": true,
                  "record_counts": {
                    "children": 150,
                    "lessons": 500,
                    "user_progress": 2500,
                    "profiles": 100,
                    "emotion_logs": 800
                  },
                  "total_records": 4050,
                  "rls_active": true,
                  "checks_passed": true
                }
              }
            }
          }
        }
      }
    },
    "/analyze-learning-profile": {
      "post": {
        "tags": ["AI"],
        "summary": "Analyze Learning Profile",
        "description": "Analyze a child's learning profile using activity history, progress data, and quiz performance to identify strengths, weaknesses, and preferred learning style.",
        "operationId": "analyzeLearningProfile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnalyzeLearningProfileRequest" },
              "example": { "childId": "uuid", "forceRefresh": false }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Learning profile analysis",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnalyzeLearningProfileResponse" },
                "example": {
                  "profile": {
                    "strengths": [{ "subject": "math", "avg_score": 92 }],
                    "weaknesses": [{ "subject": "reading", "avg_score": 65 }],
                    "preferred_subjects": ["math", "science"],
                    "average_quiz_score": 78,
                    "preferred_difficulty": "medium"
                  },
                  "cached": false,
                  "processing_time_ms": 450
                }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Child not found" }
        }
      }
    },
    "/generate-lesson-content": {
      "post": {
        "tags": ["Lessons"],
        "summary": "Generate Lesson Content",
        "description": "Generate AI-powered lesson content for a given grade level, subject, and topic. Returns structured JSON with title, markdown content, quiz questions, and metadata.",
        "operationId": "generateLessonContent",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateLessonContentRequest" },
              "example": { "grade_level": 3, "subject": "Science", "topic": "Photosynthesis" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated lesson content",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenerateLessonContentResponse" },
                "example": {
                  "title": "How Plants Make Food",
                  "description": "Learn how plants use sunlight to make their own food.",
                  "content_markdown": "# How Plants Make Food\n\n...",
                  "quiz_questions": [{ "question": "What do plants need?", "options": ["Sunlight", "Darkness"], "correct_answer": 0, "explanation": "Plants need sunlight." }],
                  "estimated_minutes": 15,
                  "points_value": 75,
                  "difficulty": "medium"
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "AI generation error" }
        }
      }
    },
    "/generate-recommendations": {
      "post": {
        "tags": ["AI"],
        "summary": "Generate Lesson Recommendations",
        "description": "Generate personalized lesson recommendations for a child based on their learning profile, completed lessons, and performance data.",
        "operationId": "generateRecommendations",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateRecommendationsRequest" },
              "example": { "childId": "uuid", "count": 5, "filterSubjects": ["math", "science"] }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recommended lessons",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenerateRecommendationsResponse" },
                "example": {
                  "recommendations": [{ "id": "uuid", "title": "Fractions Fun", "subject": "math", "reason": "Strengthen division skills" }],
                  "profile_summary": { "strengths": ["reading"], "weaknesses": ["math"] }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Access denied" }
        }
      }
    },
    "/generate-weekly-reports": {
      "post": {
        "tags": ["Analytics"],
        "summary": "Generate Weekly Reports",
